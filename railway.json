{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "main.py",
      "settings.py",
      "text_utils.py",
      "requirements.txt",
      "Dockerfile",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "python -u main.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
